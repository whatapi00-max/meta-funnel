# ─────────────────────────────────────────────────────────────
# Backend Environment Variables — copy to .env and fill values
# ─────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (Settings → API → service_role key — NEVER expose publicly)
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase anon/public key (Settings → API → anon key)
SUPABASE_ANON_KEY=your-anon-key

# JWT secret — use a long random string (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# Frontend URL for CORS (your production domain, e.g. https://mobsforsub.com)
FRONTEND_URL=https://mobsforsub.com

# Default WhatsApp number fallback (country code + number, no + sign or spaces)
DEFAULT_WHATSAPP=919876543210

# Server port (Railway/Render set this automatically)
PORT=5000
