# ───────────────────────────────────────────────────────────────────
# Frontend Environment Variables — copy to .env.local and fill values
# ───────────────────────────────────────────────────────────────────

# Backend API URL (your Railway/Render backend URL, no trailing slash)
NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# Your site's public URL (used for referral link generation)
NEXT_PUBLIC_SITE_URL=https://mobsforsub.com
